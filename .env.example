# ─── .env.example ──────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values locally.
# NEVER commit `.env`. Placeholders only in this file.

# ─── Anthropic (Claude) — Sage agent v0 ────────────────────────────────────
# Get an API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ─── RPC endpoints — testnet only ──────────────────────────────────────────
# Base Sepolia (L2 testnet). Use Alchemy, Infura, QuickNode, or public RPCs.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Deployer (testnet only) ───────────────────────────────────────────────
# WARNING: this key must NEVER hold mainnet funds. Use a dedicated testnet
# wallet. Never reuse a mainnet mnemonic here. Never commit a real value.
DEPLOYER_PRIVATE_KEY=0xREPLACE_ME_TESTNET_ONLY

# ─── Block explorers (contract verification) ───────────────────────────────
# Etherscan — used for verification of Sepolia / mainnet forks if relevant.
ETHERSCAN_API_KEY=REPLACE_ME
# Basescan — Base-specific explorer API key (can sometimes be shared with
# Etherscan multichain v2 key, kept separate for clarity and future-proofing).
BASESCAN_API_KEY=REPLACE_ME

# ─── Governance addresses ──────────────────────────────────────────────────
# Address of the community council Safe multisig. Will be populated once the
# Safe is deployed on Base Sepolia (Phase 2). Leave as placeholder until then.
COUNCIL_SAFE_ADDRESS=0x0000000000000000000000000000000000000000
