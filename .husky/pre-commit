#!/usr/bin/env sh

# Ensure common binary locations are on PATH. Some contexts
# (Claude Code subshells, cron, non-login shells, future CI workers)
# don't inherit the PATH tweaks from the user's .zshrc, so tools
# installed via brew on Apple Silicon (/opt/homebrew/bin) or
# Intel (/usr/local/bin) are invisible to `command -v` without this.
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# ─── DAOIA pre-commit hook ──────────────────────────────────────────────────
# Scans staged changes for secrets using gitleaks before allowing a commit.
#
# Requires gitleaks installed locally:
#   macOS:  brew install gitleaks
#   Linux:  see https://github.com/gitleaks/gitleaks#installing
#
# If gitleaks is missing, the hook prints a clear message and fails the
# commit rather than silently skipping the security scan.

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "✗ gitleaks is not installed."
  echo "  macOS:  brew install gitleaks"
  echo "  Linux:  see https://github.com/gitleaks/gitleaks#installing"
  echo ""
  echo "This check is mandatory (see SECURITY.md). Aborting commit."
  exit 1
fi

echo "→ Running gitleaks on staged changes..."
gitleaks protect --staged --redact --config .gitleaks.toml
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "✗ gitleaks detected a potential secret. Commit aborted."
  echo "  Review the findings above, remove the secret, then retry."
  exit $status
fi

echo "✓ gitleaks scan clean."
